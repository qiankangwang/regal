# Copy this file to .env and fill in your own value.
# Get a Deepgram API key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
PORT=3001

# Comma-separated list of allowed browser origins for CORS, e.g.
# https://yoursite.com,http://localhost:5173 . Leave empty to allow any origin
# (fine for local dev; set it for a public deployment).
ALLOWED_ORIGINS=

# Per-IP rate limit for the paid /api/transcribe proxy (protects the bill).
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Set to "true" only if the server runs behind a trusted reverse proxy, so the
# rate limiter reads the real client IP from X-Forwarded-For.
TRUST_PROXY=false
